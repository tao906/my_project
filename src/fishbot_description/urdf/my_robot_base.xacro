<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="cylinder_inertia" params="m r h">
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" /> 
            <mass value="${m}" />
            <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0" ixz="0" 
                     iyy="${(m/12) * (3*r*r + h*h)}" iyz="0" 
                     izz="${(m/2) * (r*r)}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="my_box_inertia" params="m x_dim y_dim z_dim">
        <inertial>
            <mass value="${m}"/>
            <inertia ixx="${(m/12) * (y_dim*y_dim + z_dim*z_dim)}" ixy="0.0" ixz="0.0"
                     iyy="${(m/12) * (x_dim*x_dim + z_dim*z_dim)}" iyz="0.0"
                     izz="${(m/12) * (x_dim*x_dim + y_dim*y_dim)}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="my_robot_base" params="length width height clearance">
        <link name="base_footprint" />

        <joint name="base_joint" type="fixed">
            <parent link="base_footprint" />
            <child link="base_link" />
            <origin xyz="0.0 0.0 ${clearance + height/2.0}" rpy="0 0 0" />
        </joint>

        <link name="base_link">
            <visual>
                <geometry>
                    <box size="${length} ${width} ${height}" />
                </geometry>
                <material name="blue">
                    <color rgba="0.1 0.1 0.8 1.0"/>
                </material>
            </visual>
            <collision>
                <geometry>
                    <box size="${length} ${width} ${height}" />
                </geometry>
            </collision>
            <xacro:my_box_inertia m="15.0" x_dim="${length}" y_dim="${width}" z_dim="${height}"/>
        </link>
    </xacro:macro>

    <xacro:macro name="drive_wheel" params="name xyz">
        <link name="${name}_wheel_link">
            <visual>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
                <geometry>
                    <cylinder length="0.10" radius="0.12" />
                </geometry>
                <material name="black">
                    <color rgba="0.1 0.1 0.1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
                <geometry>
                    <cylinder length="0.10" radius="0.12" />
                </geometry>
            </collision>
            <xacro:cylinder_inertia m="2.0" h="0.10" r="0.12"/>
        </link>

        <joint name="${name}_wheel_joint" type="continuous">
            <parent link="base_link" />
            <child link="${name}_wheel_link" />
            <origin xyz="${xyz}" />
            <axis xyz="0 1 0" />
        </joint>
        
        <gazebo reference="${name}_wheel_link">
            <mu1>1.0</mu1>   
            <mu2>1.0</mu2>  
            <kp>10000000.0</kp>
            <kd>1.0</kd>
        </gazebo>
    </xacro:macro>

</robot>